# =============================================================================
# cerebropax — Plantilla de variables de entorno
# =============================================================================
# COPIA este archivo a ".env" y rellena con las claves reales.
# El archivo .env NUNCA se sube a git (ver .gitignore).
# Fuente de las claves: recursospax/bitacora/01_apis-llm.md (claves canónicas)
# =============================================================================

# =============================================================================
# Llaves de los proveedores de cerebros (APIs LLM)
# =============================================================================
# Notas:
#   - Las claves canónicas (qué usar cuando hay duplicadas) están documentadas
#     en recursospax/bitacora/01_apis-llm.md (sección "Dónde está la clave").
#   - NVIDIA y DeepSeek tienen 2 claves distintas cada uno; usar la canonical.
#   - OpenRouter: REGENERAR antes de usar (clave expuesta en git histórico).
#   - OpenAI: el .env de PentAGI usa OPEN_AI_KEY (no estándar). Aquí usamos el
#     estándar OPENAI_API_KEY que LiteLLM espera.
# =============================================================================

# 🟢 Groq — gratis, rápido. Canónica: letta/.env
GROQ_API_KEY=

# 🟢 NVIDIA NIM — 121 modelos gratis. Canónica: ~/.nvidia/nvidia.env
NVIDIA_API_KEY=

# 🟡 DeepSeek — centavos. Canónica: keys.env (probar ambas, ver cuál tiene saldo)
DEEPSEEK_API_KEY=

# 🟢 Google Gemini — gratis, multimodal. Canónica: PentAGI/.env
GEMINI_API_KEY=

# 🟢 Cerebras — gratis. Canónica: keys.env
CEREBRAS_API_KEY=

# 🟡 Mistral — free tier. Canónica: keys.env
MISTRAL_API_KEY=

# 🟡 Cohere — trial (caduca). Canónica: keys.env
COHERE_API_KEY=

# 🟡 HuggingFace — gratis, lento. Canónica: keys.env
HUGGINGFACE_API_KEY=

# 🟡 OpenRouter — free + pago. 🚨 REGENERAR (expuesta en git histórico)
OPENROUTER_API_KEY=

# 🔴 OpenAI — pago, saldo desconocido. Canónica: PentAGI/.env (renombrar OPEN_AI_KEY)
OPENAI_API_KEY=

# 🔴 Anthropic — pago, saldo desconocido. Canónica: clave revelada por curl (5-jul-2026)
ANTHROPIC_API_KEY=

# =============================================================================
# Llave maestra del gateway
# =============================================================================
# Los consumidores (Letta, La Fábrica, scripts) usan ESTA llave para hablar
# con LiteLLM. Genera una con:
#   python -c "import secrets; print('sk-cerebropax-'+secrets.token_urlsafe(32))"
# (o en PowerShell):
#   python -c "import secrets; print('sk-cerebropax-'+secrets.token_urlsafe(32))"
# =============================================================================
LITELLM_MASTER_KEY=sk-cerebropax-CAMBIA-ESTO-POR-UNA-LLAVE-REAL
LITELLM_UI_TOKEN=sk-cerebropax-ui-CAMBIA-ESTO-TAMBIEN

# =============================================================================
# Salt para cifrar claves virtuales en la BD
# =============================================================================
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(32))"
LITELLM_SALT_KEY=CAMBIA-ESTO-POR-UN-SALT-ALEATORIO

# =============================================================================
# PostgreSQL interno (logs + claves virtuales)
# =============================================================================
# La contraseña puede ser cualquiera (no es externa). Cámbiala.
# IMPORTANTE: la URL debe coincidir con LITELLM_DB_PASSWORD arriba.
LITELLM_DB_PASSWORD=cerebropax_db_password_cambiar
LITELLM_DATABASE_URL=postgresql://litellm:cerebropax_db_password_cambiar@litellm_db:5432/litellm
